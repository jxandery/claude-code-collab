#!/bin/bash
# Pre-commit hook for projects with version management
# Ensures VERSION and changelog are updated when significant files change

# Find project root
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

# ============================================================================
# STAGING HYGIENE CHECK: Prevent 'git add -A' and 'git add .' anti-patterns
# ============================================================================

# Sensitive file patterns that should never be committed
SENSITIVE_PATTERNS=(
    "\.env$"
    "\.env\."
    "credentials"
    "secret"
    "\.pem$"
    "\.key$"
    "id_rsa"
    "\.password"
    "\.aws/credentials"
    "\.ssh/id"
    "database\.yml$"
)

# Check for sensitive files in staging
SENSITIVE_STAGED=""
while IFS= read -r file; do
    [[ -z "$file" ]] && continue

    # Skip template files (.example, .sample, .template)
    if [[ "$file" =~ \.(example|sample|template)$ ]]; then
        continue
    fi

    for pattern in "${SENSITIVE_PATTERNS[@]}"; do
        if [[ "$file" =~ $pattern ]]; then
            SENSITIVE_STAGED="${SENSITIVE_STAGED}${file}\n"
            break
        fi
    done
done <<< "$STAGED_FILES"

if [[ -n "$SENSITIVE_STAGED" ]]; then
    SENSITIVE_STAGED=$(echo -e "$SENSITIVE_STAGED" | sed '/^$/d')
    echo "⚠️  WARNING: Potentially sensitive files staged!"
    echo ""
    echo "Detected sensitive patterns:"
    echo "$SENSITIVE_STAGED" | while read -r file; do
        echo "  • $file"
    done
    echo ""
    echo "❌ Commit blocked to prevent accidental credential exposure"
    echo ""
    echo "If these files are safe to commit:"
    echo "  1. Review each file carefully"
    echo "  2. Add to .gitignore if they should never be committed"
    echo "  3. Override with: git commit --no-verify (only if certain)"
    exit 1
fi

# Detect bulk staging anti-patterns
# Get all modified files (staged + unstaged)
ALL_MODIFIED=$(git diff --name-only HEAD 2>/dev/null)
# grep -c always returns a number (even 0), so no fallback needed
STAGED_COUNT=$(echo "$STAGED_FILES" | grep -c '^.' 2>/dev/null)
STAGED_COUNT=$((STAGED_COUNT + 0))  # Convert to number, strip whitespace
MODIFIED_COUNT=$(echo "$ALL_MODIFIED" | grep -c '^.' 2>/dev/null)
MODIFIED_COUNT=$((MODIFIED_COUNT + 0))  # Convert to number, strip whitespace

# Calculate staging ratio (what percentage of modified files are staged)
if [[ $MODIFIED_COUNT -gt 0 ]] && [[ $STAGED_COUNT -gt 5 ]]; then
    STAGING_RATIO=$((STAGED_COUNT * 100 / MODIFIED_COUNT))

    # If >90% of modified files are staged AND >5 files, likely bulk add
    if [[ $STAGING_RATIO -gt 90 ]]; then
        # Check if this is a legitimate version bump commit
        VERSION_STAGED=$(echo "$STAGED_FILES" | grep -cE "(^VERSION$|/VERSION$)" 2>/dev/null)
        VERSION_STAGED=$((VERSION_STAGED + 0))  # Convert to number
        CHANGELOG_STAGED=$(echo "$STAGED_FILES" | grep -cE "(^\.meta/changelog\.md$|/\.meta/changelog\.md$)" 2>/dev/null)
        CHANGELOG_STAGED=$((CHANGELOG_STAGED + 0))  # Convert to number

        # Version bump commits are expected to stage multiple files
        # Non-blocking: can't distinguish explicit staging from bulk add
        if [[ $VERSION_STAGED -eq 0 ]] || [[ $CHANGELOG_STAGED -eq 0 ]]; then
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "📋 Many files staged ($STAGED_COUNT files)"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            echo "Staged files:"
            echo "$STAGED_FILES" | head -10 | while read -r file; do
                echo "  • $file"
            done
            if [[ $STAGED_COUNT -gt 10 ]]; then
                echo "  ... and $((STAGED_COUNT - 10)) more files"
            fi
            echo ""
            echo "Why explicit staging matters:"
            echo "  • Prevents accidentally committing unrelated changes"
            echo "  • Avoids cross-project contamination"
            echo "  • Makes commit intent clear"
            echo "  • Reduces risk of committing sensitive data"
            echo ""
            echo "✓ If staged explicitly → proceed"
            echo "✗ If used 'git add -A' → git reset && git add <files>"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            # Continue - informational only, not blocking
        fi
    fi
fi

# ============================================================================

# Exclusion list: Files that don't require version bumps
# These are either auto-updated (VERSION, changelog) or non-functional (config files)
# Patterns support both root-level and monorepo (subdirectory) structures
EXCLUDED_PATTERNS=(
    "(^VERSION$|/VERSION$)"
    "(^\.meta/changelog\.md$|/\.meta/changelog\.md$)"
    "(^\.meta/changelogs/.*\.md$|/\.meta/changelogs/.*\.md$)"
    "^\.gitignore$"
    "^\.gitattributes$"
    "^LICENSE$"
    "^\.DS_Store$"
    "^TODO\.md$"
    "^\.claude/"                # Workspace infrastructure (hooks, config, agents)
)

# Filter out excluded files
SIGNIFICANT_FILES=""
while IFS= read -r file; do
    [[ -z "$file" ]] && continue

    # Check if file matches any exclusion pattern
    EXCLUDED=false
    for pattern in "${EXCLUDED_PATTERNS[@]}"; do
        if [[ "$file" =~ $pattern ]]; then
            EXCLUDED=true
            break
        fi
    done

    # If not excluded, it's significant
    if [[ "$EXCLUDED" = false ]]; then
        SIGNIFICANT_FILES="${SIGNIFICANT_FILES}${file}\n"
    fi
done <<< "$STAGED_FILES"

# Remove trailing newline and count significant files
SIGNIFICANT_FILES=$(echo -e "$SIGNIFICANT_FILES" | sed '/^$/d')
SIGNIFICANT_COUNT=$(echo "$SIGNIFICANT_FILES" | grep -c . || true)

if [[ $SIGNIFICANT_COUNT -gt 0 ]]; then
    # Check if VERSION file is also staged (support monorepo with */VERSION pattern)
    VERSION_STAGED=$(echo "$STAGED_FILES" | grep -cE "(^VERSION$|/VERSION$)" || true)
    CHANGELOG_STAGED=$(echo "$STAGED_FILES" | grep -cE "(^\.meta/changelog\.md$|/\.meta/changelog\.md$)" || true)

    if [[ $VERSION_STAGED -eq 0 ]] || [[ $CHANGELOG_STAGED -eq 0 ]]; then
        echo "❌ Pre-commit hook failed!"
        echo ""
        echo "You modified project files but didn't update VERSION or changelog."
        echo ""
        echo "Modified files:"
        echo "$SIGNIFICANT_FILES" | while read -r file; do
            echo "  • $file"
        done
        echo ""
        echo "Run version bump script:"
        echo "  ./scripts/bump-version.sh [major|minor|patch]"
        echo ""
        echo "Or manually update VERSION and .meta/changelog.md"
        echo ""
        echo "Amending a version bump commit to add missed files?"
        echo "  git commit --amend --no-verify --no-edit"
        echo "  (The safety net will auto-approve if HEAD has VERSION bump)"
        echo ""
        echo "To see validation status:"
        echo "  ~/claude-workspace/scripts/validate-commit-requirements.sh --pre-commit"
        exit 1
    fi
fi

# Additional validation: If VERSION is staged, verify detailed changelog exists
# This prevents manual VERSION edits that bypass the bump-version.sh workflow
VERSION_FILE=$(echo "$STAGED_FILES" | grep -E "(^VERSION$|/VERSION$)" | head -n 1)
if [[ -n "$VERSION_FILE" ]]; then
    # Get the staged VERSION content (what's being committed)
    STAGED_VERSION=$(git show :"$VERSION_FILE" 2>/dev/null || cat "$VERSION_FILE")
    STAGED_VERSION=$(echo "$STAGED_VERSION" | tr -d '\n' | tr -d ' ')

    # Determine changelog directory (same directory as VERSION file)
    VERSION_DIR=$(dirname "$VERSION_FILE")
    if [[ "$VERSION_DIR" == "." ]]; then
        DETAILED_CHANGELOG=".meta/changelogs/${STAGED_VERSION}.md"
    else
        DETAILED_CHANGELOG="${VERSION_DIR}/.meta/changelogs/${STAGED_VERSION}.md"
    fi

    if [[ ! -f "$DETAILED_CHANGELOG" ]]; then
        echo "❌ Pre-commit hook failed!"
        echo ""
        echo "Missing detailed changelog file: $DETAILED_CHANGELOG"
        echo ""
        echo "VERSION is being updated to $STAGED_VERSION, but the detailed"
        echo "changelog file doesn't exist."
        echo ""
        echo "Did you run the version bump script?"
        echo "  ./scripts/bump-version.sh [major|minor|patch]"
        echo ""
        echo "Or manually create: $DETAILED_CHANGELOG"
        echo ""
        echo "To see validation status:"
        echo "  ~/claude-workspace/scripts/validate-commit-requirements.sh --pre-commit"
        echo ""
        echo "Using --no-verify? The safe-commit wrapper will require manual approval."
        exit 1
    fi

    # Check if main changelog references the detailed changelog
    if [[ "$VERSION_DIR" == "." ]]; then
        MAIN_CHANGELOG=".meta/changelog.md"
    else
        MAIN_CHANGELOG="${VERSION_DIR}/.meta/changelog.md"
    fi

    if [[ -f "$MAIN_CHANGELOG" ]]; then
        if ! grep -q "(changelogs/${STAGED_VERSION}.md)" "$MAIN_CHANGELOG"; then
            echo "❌ Pre-commit hook failed!"
            echo ""
            echo "Main changelog doesn't reference detailed changelog"
            echo ""
            echo "VERSION is $STAGED_VERSION, but $MAIN_CHANGELOG"
            echo "doesn't contain a link to (changelogs/${STAGED_VERSION}.md)"
            echo ""
            echo "Did you run the version bump script?"
            echo "  ./scripts/bump-version.sh [major|minor|patch]"
            echo ""
            echo "Or manually add the link to $MAIN_CHANGELOG"
            echo ""
            echo "To see validation status:"
            echo "  ~/claude-workspace/scripts/validate-commit-requirements.sh --pre-commit"
            echo ""
            echo "Using --no-verify? The safe-commit wrapper will require manual approval."
            exit 1
        fi
    fi
fi

# Check markdown table alignment (staged .md files only)
# Only runs if the workspace script exists (graceful degradation for projects that haven't synced)
if [[ -f "$HOME/claude-workspace/scripts/validate-table-alignment.sh" ]]; then
    STAGED_MD_FILES=$(echo "$STAGED_FILES" | grep '\.md$' || true)
    if [[ -n "$STAGED_MD_FILES" ]]; then
        echo "Checking markdown table alignment..."
        if ! "$HOME/claude-workspace/scripts/validate-table-alignment.sh" --staged-only; then
            echo ""
            echo "❌ Table alignment check failed!"
            echo ""
            echo "Markdown tables must have vertically aligned pipes."
            echo "To auto-fix: ~/claude-workspace/scripts/validate-table-alignment.sh --fix"
            echo "Then re-stage the fixed files."
            exit 1
        fi
    fi
fi

# All workspace checks passed

# Signal to prepare-commit-msg that pre-commit ran for THIS commit
# Using PPID (git's PID) to detect stale markers from cancelled commits
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null || echo ".git")
echo "$PPID" > "$GIT_DIR/pre-commit-passed"

# Source project-specific pre-commit logic if it exists
# This allows projects to add custom validations without modifying this file
# Example: .claude/git-hooks/pre-commit.local can add linting, testing, etc.
LOCAL_HOOK="$PROJECT_ROOT/.claude/git-hooks/pre-commit.local"
if [[ -f "$LOCAL_HOOK" ]]; then
    # shellcheck source=/dev/null
    source "$LOCAL_HOOK"
    LOCAL_EXIT_CODE=$?
    if [[ $LOCAL_EXIT_CODE -ne 0 ]]; then
        echo ""
        echo "❌ Project-specific pre-commit checks failed"
        echo "   (from .claude/git-hooks/pre-commit.local)"
        exit $LOCAL_EXIT_CODE
    fi
fi

exit 0
