#!/bin/bash
# Commit message validation hook
# Ensures commits follow the [Type]: Summary format
#
# This hook is triggered by git commit and validates the commit message format
# before the commit is finalized.
#
# DEFAULT BEHAVIOR:
# - Enforces [Type]: Summary format on first line
# - Valid types: Bug Fix, Chore, Feature, Documentation, Miscellaneous, Refactor
# - Blocks Claude Code attribution (non-negotiable)
# - Validates basic formatting and indentation
#
# CUSTOMIZATION:
# Projects can modify this hook after copying from the template:
# - Edit VALID_TYPES_REGEX to change acceptable commit types
# - Adjust indentation validation strictness (warning vs error)
# - Add project-specific validations
#
# NOTE: Claude Code attribution blocking is intentionally non-configurable.
# This reflects a deliberate project preference to exclude AI attribution.
#
# IMPORTANT: Do NOT use [Minor], [Patch], or [Major] commit types.
# Those are reserved exclusively for the claude-workspace repository itself.

COMMIT_MSG_FILE=$1

# Exempt merge commits from validation
# Merge commits are integration ceremony, not substantive changes
# The individual commits being merged already have proper [Type]: prefixes
if git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
    exit 0
fi

COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)

# ANSI color codes for better readability
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Define valid commit types
# Projects can modify this regex after copying the template
VALID_TYPES_REGEX='^\[(Bug Fix|Chore|Feature|Documentation|Miscellaneous|Refactor)\]:'

# Validate commit message format: [Type]: Summary
if ! echo "$FIRST_LINE" | grep -qE "$VALID_TYPES_REGEX"; then
    echo -e "${RED}❌ Invalid commit message format!${NC}"
    echo ""
    echo "The first line must follow this format:"
    echo -e "  ${GREEN}[Type]: Brief summary (50 chars or less)${NC}"
    echo ""
    echo "Valid types:"
    echo "  • Bug Fix         - Fixes a bug or regression"
    echo "  • Chore           - Maintenance, tooling, dependencies"
    echo "  • Feature         - New functionality"
    echo "  • Documentation   - Documentation changes"
    echo "  • Miscellaneous   - Other changes that don't fit above"
    echo "  • Refactor        - Code improvements without functional changes"
    echo ""
    echo "Your first line:"
    echo -e "  ${YELLOW}$FIRST_LINE${NC}"
    echo ""
    echo "Example valid formats:"
    echo -e "  ${GREEN}[Chore]: Add git hooks for commit validation${NC}"
    echo -e "  ${GREEN}[Bug Fix]: Correct VERSION file path in script${NC}"
    echo -e "  ${GREEN}[Feature]: Add template distribution system${NC}"
    echo -e "  ${GREEN}[Refactor]: Extract validation logic into separate module${NC}"
    echo ""
    echo "To fix: git commit --amend"
    exit 1
fi

# Check for forbidden Claude Code attribution
# This is intentionally non-configurable
if echo "$COMMIT_MSG" | grep -qi "🤖.*claude code\|claude.com/claude-code\|co-authored-by: claude"; then
    echo -e "${RED}❌ Commit contains forbidden Claude Code attribution!${NC}"
    echo ""
    echo "This project uses a custom commit format that excludes"
    echo "Claude Code attribution lines."
    echo ""
    echo "Please remove these lines:"
    echo "  • 🤖 Generated with [Claude Code](...)"
    echo "  • Co-Authored-By: Claude <...>"
    echo ""
    echo "To fix: git commit --amend"
    exit 1
fi

# Validate indentation (messages should use 2-space indent for context/bullets)
# This is a non-fatal warning by default, projects can make it stricter
LINE_COUNT=$(echo "$COMMIT_MSG" | wc -l | tr -d ' ')
if [ "$LINE_COUNT" -gt 1 ]; then
    # Check if second line (context paragraph) starts with 2 spaces
    SECOND_LINE=$(echo "$COMMIT_MSG" | sed -n '2p')
    if [ -n "$SECOND_LINE" ] && ! echo "$SECOND_LINE" | grep -qE '^  [^ ]'; then
        echo -e "${YELLOW}⚠️  Warning: Context paragraph should start with 2-space indent${NC}"
        echo ""
        echo "Expected format:"
        echo "  [Type]: Summary"
        echo ""
        echo "    Context paragraph with 2-space indent..."
        echo ""
        echo "    - Bullet point with 2-space indent"
        echo ""
        echo "Current second line:"
        echo "  '$SECOND_LINE'"
        echo ""
        echo "To fix: git commit --amend"
        # Non-fatal warning for now
        # Uncomment to make this a hard failure:
        # exit 1
    fi
fi

# All workspace validations passed

# Source project-specific commit-msg logic if it exists
# This allows projects to add custom commit message validations without modifying this file
# Example: .claude/git-hooks/commit-msg.local can enforce ticket numbers, signing, etc.
# The local hook has access to: COMMIT_MSG_FILE, COMMIT_MSG, FIRST_LINE
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
LOCAL_HOOK="$PROJECT_ROOT/.claude/git-hooks/commit-msg.local"
if [[ -f "$LOCAL_HOOK" ]]; then
    # shellcheck source=/dev/null
    source "$LOCAL_HOOK"
    LOCAL_EXIT_CODE=$?
    if [[ $LOCAL_EXIT_CODE -ne 0 ]]; then
        echo ""
        echo "❌ Project-specific commit message validation failed"
        echo "   (from .claude/git-hooks/commit-msg.local)"
        exit $LOCAL_EXIT_CODE
    fi
fi

exit 0
